# =============================================================
# Hummingbird Instinct — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================

# ----- Server ------------------------------------------------
NODE_ENV=development
PORT=4000

# SQLite database file path (Phase 1 local)
# Phase 3: Replace with Azure SQL connection string via DB_CONNECTION_STRING
DB_PATH=./data/instinct.db

# ----- AI (Anthropic Claude) ---------------------------------
# Required for: Artifact Ingestion, Knowledge Hub, Interview Studio AI Review,
#               Engagement Setup SOW Analysis
# Without this key, AI features return a graceful 503. Core note-taking works offline.
ANTHROPIC_API_KEY=

# Claude model to use for extraction tasks
ANTHROPIC_MODEL=claude-opus-4-6

# Claude model to use for Knowledge Hub queries (can use a faster model)
ANTHROPIC_QUERY_MODEL=claude-opus-4-6

# ----- SharePoint / Microsoft Graph API ----------------------
# SHAREPOINT_STUB: These are required for SharePoint integration.
# All SharePoint features are stubbed until these are provided.
# Prerequisite: Azure AD app registration with 6 permissions consented (see PRD §9.5)
# Must be confirmed with Hummingbird IT before enabling SharePoint features.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# The SharePoint site used for the active engagement (set per-engagement via UI in production)
SHAREPOINT_SITE_URL=

# ----- File Upload -------------------------------------------
# Max file size for artifact uploads (bytes). Default = 50MB per PRD §7.2.1
MAX_FILE_SIZE_BYTES=52428800

# Local upload storage directory (Phase 1)
UPLOAD_DIR=./uploads

# ----- Vector Store ------------------------------------------
# Phase 1: in-memory keyword search (no config needed)
# Phase 3: Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX_NAME=instinct-vectors

# RAG retrieval depth (number of records sent to Claude for KH queries)
VECTOR_SEARCH_TOP_K=50

# Threshold: knowledge bases with MORE than this many findings use RAG pre-filtering
RAG_THRESHOLD=200

# ----- Security ----------------------------------------------
# Phase 1: local dev uses a stub user (see server/src/middleware/auth.js)
# Phase 3: Azure AD / Entra ID SSO — validate JWT here
# JWT_AUDIENCE=
# JWT_ISSUER=https://login.microsoftonline.com/${AZURE_TENANT_ID}/v2.0

# ----- Client (Vite reads VITE_ prefix) ----------------------
# These are safe to expose — they point at YOUR server, not directly at any API
VITE_API_BASE_URL=http://localhost:4000/api
